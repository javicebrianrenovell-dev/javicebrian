---
import BaseLayout from './BaseLayout.astro';
import Schema from '../components/Schema.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  service: CollectionEntry<'services'>;
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { service, relatedPosts = [] } = Astro.props;
const {
  title,
  seoTitle,
  description,
  claim,
  heroImage,
  cluster,
  problema,
  metodo,
  casos,
  faq,
  cta,
} = service.data;

const SITE_URL = 'https://javicebrian.es';
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

const categoriaLabel: Record<string, string> = {
  comunicacion: 'Comunicación',
  sostenibilidad: 'Sostenibilidad',
  ia: 'Inteligencia Artificial',
  herramientas: 'Herramientas',
};

// Schema: Service + FAQPage + BreadcrumbList
const serviceSchema = {
  name: title,
  description,
  serviceType: title,
  url: canonicalURL,
};

const faqSchema =
  faq.length > 0
    ? {
        mainEntity: faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : null;

const breadcrumbSchema = {
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE_URL + '/' },
    { '@type': 'ListItem', position: 2, name: title, item: canonicalURL },
  ],
};
---

<BaseLayout title={title} seoTitle={seoTitle} description={description} image={heroImage}>
  <Schema type="Service" data={serviceSchema} />
  {faqSchema && <Schema type="FAQPage" data={faqSchema} />}
  <Schema type="BreadcrumbList" data={breadcrumbSchema} />

  <!-- HERO -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7] relative overflow-hidden min-h-[68vh] flex items-end pb-16 pt-32">
    <div class="container-wide w-full relative z-5">
      <nav class="font-display text-xs text-[#A0A0A0] mb-8" aria-label="Migas de pan" data-reveal>
        <a href="/" class="hover:text-[#8DBE3F] transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-[#8DBE3F]">{categoriaLabel[cluster]}</span>
      </nav>
      <span class="acento-verde block mb-6" data-mask-up></span>
      <h1
        class="m-0 font-extrabold text-[#FAFAF7] leading-[0.9] tracking-[-0.03em]"
        style="font-size: clamp(2.75rem, 8vw, 6.5rem); max-width: 16ch;"
      >
        <span data-mask-up>{claim}</span>
      </h1>
      <p class="mt-8 text-lg md:text-xl leading-relaxed text-[#FAFAF7]/85 max-w-2xl" data-reveal data-delay="200">
        {description}
      </p>
      <div class="flex gap-3 mt-10 flex-wrap" data-reveal data-delay="350">
        <a href="/trabajemos-juntos/" data-magnetic="0.3" class="inline-flex items-center gap-2 px-8 py-4 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
          {cta.titulo} →
        </a>
      </div>
    </div>
  </section>

  <!-- PROBLEMA -->
  <section class="bg-[#FAFAF7] text-[#1A1A1A]">
    <div class="container-wide py-24 md:py-32">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4 md:sticky md:top-28">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#467010] m-0">§ 01</p>
          <p class="font-display text-xs text-[#6B6B6B] mt-2">EL PROBLEMA</p>
        </div>
        <div class="md:col-span-8">
          <h2 class="font-extrabold m-0 leading-[1.05] tracking-[-0.03em]" style="font-size: clamp(1.75rem, 4vw, 3.25rem); max-width: 22ch;" data-mask-up>
            <span>{problema.titulo}</span>
          </h2>
          <p class="mt-8 text-lg md:text-xl leading-relaxed text-[#3D3D3D] max-w-2xl" data-reveal data-delay="150">
            {problema.body}
          </p>
          <div class="prose-custom mt-8 max-w-2xl" data-reveal data-delay="200">
            <slot />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MÉTODO -->
  {metodo.length > 0 && (
    <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
      <div class="container-wide py-24 md:py-32">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start mb-12">
          <div class="md:col-span-4">
            <span class="acento-verde block mb-6" data-reveal></span>
            <p class="font-display text-xs text-[#8DBE3F] m-0">§ 02</p>
            <p class="font-display text-xs text-[#A0A0A0] mt-2">CÓMO TRABAJO</p>
          </div>
          <div class="md:col-span-8">
            <h2 class="font-extrabold m-0 leading-[1.05] tracking-[-0.03em]" style="font-size: clamp(1.75rem, 4vw, 3.25rem); max-width: 18ch;" data-mask-up>
              <span>Un método, no una ocurrencia.</span>
            </h2>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
          <div class="md:col-start-5 md:col-span-8">
            {metodo.map((m, i) => (
              <div class="py-7 grid grid-cols-1 sm:grid-cols-12 gap-4" style={i > 0 ? 'border-top: 1px solid rgba(255,255,255,0.1);' : ''} data-reveal data-delay={`${i * 90}`}>
                <p class="sm:col-span-2 font-display text-3xl text-[#8DBE3F] m-0 leading-none">{m.num}</p>
                <div class="sm:col-span-10">
                  <h3 class="font-extrabold m-0 leading-tight tracking-[-0.02em]" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem);">{m.titulo}</h3>
                  <p class="mt-3 text-base md:text-lg leading-relaxed text-[#A0A0A0] max-w-2xl">{m.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CASOS DE USO -->
  {casos.length > 0 && (
    <section class="bg-[#FAFAF7] text-[#1A1A1A]">
      <div class="container-wide py-24 md:py-32">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
          <div class="md:col-span-4">
            <span class="acento-verde block mb-6" data-reveal></span>
            <p class="font-display text-xs text-[#467010] m-0">§ 03</p>
            <p class="font-display text-xs text-[#6B6B6B] mt-2">CASOS DE USO</p>
            <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.5rem, 3vw, 2.5rem); max-width: 14ch;" data-mask-up>
              <span>Dónde encaja.</span>
            </h2>
          </div>
          <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-7">
            {casos.map((c, i) => (
              <div class="flex gap-3" data-reveal data-delay={`${i * 70}`}>
                <span class="text-[#8DBE3F] font-bold">→</span>
                <p class="m-0 text-base md:text-lg leading-relaxed text-[#3D3D3D]">{c}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {faq.length > 0 && (
    <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
      <div class="container-wide py-24 md:py-32">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
          <div class="md:col-span-4">
            <span class="acento-verde block mb-6" data-reveal></span>
            <p class="font-display text-xs text-[#8DBE3F] m-0">§ 04</p>
            <p class="font-display text-xs text-[#A0A0A0] mt-2">PREGUNTAS</p>
          </div>
          <div class="md:col-span-8">
            {faq.map((f, i) => (
              <details class="py-5 group" style={i > 0 ? 'border-top: 1px solid rgba(255,255,255,0.1);' : ''} data-reveal data-delay={`${i * 60}`}>
                <summary class="cursor-pointer list-none flex justify-between items-start gap-4 font-semibold text-lg md:text-xl leading-snug">
                  <span>{f.q}</span>
                  <span class="text-[#8DBE3F] transition-transform group-open:rotate-45 shrink-0">+</span>
                </summary>
                <p class="mt-4 text-base md:text-lg leading-relaxed text-[#A0A0A0] max-w-2xl">{f.a}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ARTÍCULOS DEL CLUSTER -->
  {relatedPosts.length > 0 && (
    <section class="bg-[#FAFAF7] text-[#1A1A1A]">
      <div class="container-wide py-24 md:py-32">
        <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
          <div>
            <span class="acento-verde block mb-6" data-reveal></span>
            <p class="font-display text-xs text-[#467010] m-0">§ 05</p>
            <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-4" style="font-size: clamp(1.5rem, 3vw, 2.5rem);" data-mask-up>
              <span>Sigue leyendo</span>
            </h2>
          </div>
          <a href="/blog/" class="font-display text-xs text-[#1A1A1A] hover:text-[#8DBE3F] transition-colors">VER TODO EL BLOG →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((rp, i) => (
            <a href={`/blog/${rp.slug}/`} class="group block" data-reveal data-delay={`${i * 90}`}>
              {rp.data.heroImage && (
                <img src={rp.data.heroImage} alt={`Imagen del artículo: ${rp.data.title}`} class="w-full h-44 object-cover rounded-md mb-4 transition-transform duration-700 group-hover:scale-[1.03]" loading="lazy" />
              )}
              <p class="font-display text-xs text-[#467010] m-0">{categoriaLabel[rp.data.category]}</p>
              <h3 class="font-bold mt-2 leading-snug tracking-[-0.01em] group-hover:text-[#467010] transition-colors" style="font-size: 1.15rem;">{rp.data.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA FINAL -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container-wide py-24 md:py-32">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-end">
        <div class="md:col-span-7">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#8DBE3F] mb-4" data-reveal>§ HABLAMOS</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[0.95] m-0" style="font-size: clamp(2.5rem, 7vw, 6rem); max-width: 14ch;">
            <span data-mask-up>{cta.titulo}</span>
          </h2>
          <p class="mt-8 text-lg md:text-xl text-[#A0A0A0] max-w-xl leading-relaxed" data-reveal data-delay="200">
            {cta.texto}
          </p>
        </div>
        <div class="md:col-span-5 md:text-right" data-reveal data-delay="300">
          <a href="/trabajemos-juntos/" data-magnetic="0.3" class="inline-flex items-center gap-2 px-10 py-5 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
            Cuéntame tu reto →
          </a>
          <p class="mt-6 text-xs text-[#A0A0A0]">
            ¿Solo una duda rápida? <a href="/contacto/" class="text-[#FAFAF7] hover:text-[#8DBE3F] transition-colors">Escríbeme aquí</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
