---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  lastUpdated: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description} noindex={false}>
  <article>
    <header class="bg-[#1A1A1A] text-[#FAFAF7]">
      <div class="container-base py-16 md:py-20">
        <div class="acento-verde mb-6" data-stagger-line></div>
        <p class="font-display text-sm text-[#8DBE3F] mb-3" data-stagger-line>LEGAL</p>
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-tighter leading-[1.1] max-w-3xl" data-stagger-line>
          {title}
        </h1>
        <p class="mt-6 text-sm text-[#A0A0A0]" data-stagger-line>
          Última actualización: {lastUpdated}
        </p>
      </div>
    </header>

    <div class="container-base py-12 md:py-16">
      <div class="prose-custom max-w-3xl mx-auto" data-reveal>
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
