---
import '../styles/global.css';

// Fuentes self-hosted (RGPD compliant, sin Google Fonts)
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/inter/900.css';
import '@fontsource/bebas-neue/400.css';

import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';
import { GA_MEASUREMENT_ID } from '../consts';

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  seoTitle,
  description = 'Director de Comunicación y Desarrollo de Negocio. Comunicación que mueve organizaciones, con sostenibilidad e IA como ventaja.',
  image = '/og-default.jpg',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const siteName = 'Javi Cebrián';
// seoTitle (corto, <60 car.) prevalece sobre el título visible para el <title> y OG.
const headTitle = seoTitle ?? title;
const fullTitle = headTitle.includes('Javi Cebrián') ? headTitle : `${headTitle} · ${siteName}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <Schema type="WebSite" />

    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    {GA_MEASUREMENT_ID && (
      <div
        id="cookie-consent"
        class="hidden fixed bottom-0 left-0 right-0 z-50 bg-[#1A1A1A] text-[#FAFAF7] border-t border-[#8DBE3F]/40"
        role="dialog"
        aria-live="polite"
        aria-label="Aviso de cookies"
      >
        <div class="container-wide py-5 flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
          <p class="text-sm leading-relaxed text-[#FAFAF7]/85 max-w-2xl m-0">
            Uso cookies de medición (Google Analytics) solo para entender qué contenido te resulta útil.
            Nada de publicidad. Puedes aceptarlas o rechazarlas. Más detalle en la
            <a href="/politica-de-cookies/" class="underline text-[#FAFAF7] hover:text-[#8DBE3F]">política de cookies</a>.
          </p>
          <div class="flex items-center gap-3 shrink-0">
            <button
              id="cookie-reject"
              type="button"
              class="px-5 py-2.5 text-sm font-semibold text-[#FAFAF7] border border-[#FAFAF7]/25 rounded-md hover:bg-[#FAFAF7]/10 transition-colors"
            >
              Rechazar
            </button>
            <button
              id="cookie-accept"
              type="button"
              class="px-6 py-2.5 text-sm font-bold text-[#1A1A1A] bg-[#8DBE3F] rounded-md hover:bg-[#FAFAF7] transition-colors"
            >
              Aceptar
            </button>
          </div>
        </div>
      </div>
    )}

    <script>
      import { initAnimations } from '../scripts/animations';
      import { initAnalytics } from '../scripts/analytics';

      // Primera carga
      initAnimations();
      initAnalytics();

      // Re-init tras View Transitions de Astro
      document.addEventListener('astro:page-load', () => {
        initAnimations();
        initAnalytics();
      });
    </script>
  </body>
</html>
