---
import BaseLayout from './BaseLayout.astro';
import Schema from '../components/Schema.astro';
import type { CollectionEntry } from 'astro:content';

interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime?: number;
  toc?: TocItem[];
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { post, readingTime = 0, toc = [], relatedPosts = [] } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, category, tags } = post.data;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const heroImageURL = heroImage
  ? new URL(heroImage, Astro.site).href
  : new URL('/og-default.jpg', Astro.site).href;

const categoriaLabel: Record<string, string> = {
  comunicacion: 'Comunicación',
  sostenibilidad: 'Sostenibilidad',
  ia: 'Inteligencia Artificial',
  herramientas: 'Herramientas',
};

const dateFormatter = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Enlaces para compartir
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalURL)}`;
const shareX = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonicalURL)}`;
const shareWhatsApp = `https://api.whatsapp.com/send?text=${encodeURIComponent(title + ' ' + canonicalURL)}`;
---

<BaseLayout title={title} description={description} image={heroImage}>
  <Schema
    type="BlogPosting"
    data={{
      headline: title,
      description,
      datePublished: pubDate.toISOString(),
      dateModified: (updatedDate ?? pubDate).toISOString(),
      image: heroImageURL,
      mainEntityOfPage: canonicalURL,
      url: canonicalURL,
      keywords: tags.join(', '),
      articleSection: category,
    }}
  />

  <article>
    <!-- HERO del post -->
    <header class="bg-[#1A1A1A] text-[#FAFAF7]">
      <div class="container-base py-20 md:py-28">
        <div class="max-w-4xl">
          <div class="acento-verde mb-8" data-stagger-line></div>
          <a href="/blog/" class="font-display text-sm text-[#8DBE3F] mb-4 inline-block hover:text-[#FAFAF7] transition-colors" data-stagger-line>
            ← BLOG · {categoriaLabel[category]}
          </a>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.15] tracking-tight mt-4" data-stagger-line>
            {title}
          </h1>
          <p class="mt-6 text-lg text-[#A0A0A0] max-w-2xl" data-stagger-line>
            {description}
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4 text-sm text-[#A0A0A0]" data-stagger-line>
            <time datetime={pubDate.toISOString()}>{dateFormatter.format(pubDate)}</time>
            {updatedDate && (
              <>
                <span aria-hidden="true">·</span>
                <span>Actualizado {dateFormatter.format(updatedDate)}</span>
              </>
            )}
            {readingTime > 0 && (
              <>
                <span aria-hidden="true">·</span>
                <span>{readingTime} min de lectura</span>
              </>
            )}
            <span aria-hidden="true">·</span>
            <span>Javi Cebrián</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Imagen destacada (si hay) -->
    {heroImage && (
      <div class="container-base mt-[-2rem] mb-12 max-w-4xl" data-reveal>
        <img
          src={heroImage}
          alt={`Imagen destacada del artículo: ${title}`}
          class="w-full h-auto rounded-lg shadow-2xl border border-[#1A1A1A]/10"
          loading="eager"
        />
      </div>
    )}

    <!-- Contenido del post -->
    <div class="container-base py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <!-- Índice de contenidos -->
        {toc.length >= 3 && (
          <nav class="toc-box" aria-label="Índice de contenidos" data-reveal>
            <p class="toc-title">En este artículo</p>
            <ol>
              {toc.map(item => (
                <li><a href={`#${item.slug}`}>{item.text}</a></li>
              ))}
            </ol>
          </nav>
        )}

        <div class="prose-custom" data-reveal>
          <slot />
        </div>

        <!-- Compartir -->
        <div class="max-w-3xl mx-auto mt-14 pt-8 border-t border-[#E5E5E0] flex flex-wrap items-center gap-3" data-reveal>
          <span class="font-display text-xs text-[#1A1A1A] mr-1">COMPARTIR</span>
          <a href={shareLinkedIn} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en LinkedIn">LinkedIn</a>
          <a href={shareX} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en X">X</a>
          <a href={shareWhatsApp} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en WhatsApp">WhatsApp</a>
          <button type="button" class="share-btn" data-copy-url={canonicalURL} aria-label="Copiar enlace">Copiar enlace</button>
        </div>

        <!-- Tags -->
        {tags && tags.length > 0 && (
          <div class="max-w-3xl mx-auto mt-10" data-reveal>
            <p class="font-display text-xs text-[#1A1A1A] mb-4">ETIQUETAS</p>
            <ul class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <li class="px-3 py-1.5 bg-[#FAFAF7] border border-[#E5E5E0] text-xs font-semibold text-[#3D3D3D] rounded-md">
                  {tag}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>

    <!-- Posts relacionados -->
    {relatedPosts.length > 0 && (
      <section class="bg-[#FAFAF7] border-t border-[#E5E5E0]">
        <div class="container-wide py-16 md:py-20">
          <p class="font-display text-xs text-[#8DBE3F] mb-2">§ SIGUE LEYENDO</p>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-10">Artículos relacionados</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedPosts.map(rp => (
              <a href={`/blog/${rp.slug}/`} class="group block no-underline">
                {rp.data.heroImage && (
                  <img
                    src={rp.data.heroImage}
                    alt={`Imagen del artículo: ${rp.data.title}`}
                    class="w-full h-44 object-cover rounded-lg mb-4 transition-transform duration-700 group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                )}
                <p class="font-display text-xs text-[#467010] mb-2">{categoriaLabel[rp.data.category]}</p>
                <h3 class="text-lg font-bold leading-snug text-[#1A1A1A] group-hover:text-[#467010] transition-colors">{rp.data.title}</h3>
                <p class="mt-2 text-sm text-[#6B6B6B] leading-relaxed line-clamp-3">{rp.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA final del post -->
    <section class="bg-[#1A1A1A] text-[#FAFAF7]">
      <div class="container-base py-20 md:py-24 text-center">
        <div class="acento-verde mx-auto mb-8" data-reveal></div>
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tighter mb-6" data-reveal>
          ¿Hablamos de tu proyecto?
        </h2>
        <p class="text-lg text-[#A0A0A0] max-w-xl mx-auto mb-10" data-reveal>
          Si lo que has leído conecta con un reto que tienes ahora mismo, una conversación de 30 minutos te aclara más que mil artículos.
        </p>
        <a href="/contacto/" data-magnetic="0.3" class="inline-flex items-center gap-2 px-10 py-5 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
          Contacta →
        </a>
      </div>
    </section>
  </article>

  <script>
    function initCopyButtons() {
      document.querySelectorAll<HTMLButtonElement>('[data-copy-url]').forEach(btn => {
        if (btn.dataset.copyBound) return;
        btn.dataset.copyBound = 'true';
        btn.addEventListener('click', async () => {
          const url = btn.getAttribute('data-copy-url') || window.location.href;
          try {
            await navigator.clipboard.writeText(url);
            const original = btn.textContent;
            btn.textContent = 'Enlace copiado';
            setTimeout(() => { btn.textContent = original; }, 2000);
          } catch {
            window.prompt('Copia el enlace:', url);
          }
        });
      });
    }
    initCopyButtons();
    document.addEventListener('astro:page-load', initCopyButtons);
  </script>
</BaseLayout>

<style is:global>
  /* Estilos del contenido del post */
  .prose-custom {
    color: var(--color-gris-texto);
    font-size: 1.125rem;
    line-height: 1.75;
  }

  /* Entradilla: primer párrafo destacado */
  .prose-custom > p:first-of-type {
    font-size: 1.35rem;
    line-height: 1.6;
    color: var(--color-negro);
    margin-bottom: 1.75rem;
  }

  /* Capitular editorial en la primera letra */
  .prose-custom > p:first-of-type::first-letter {
    float: left;
    font-family: var(--font-display);
    font-size: 4.2rem;
    line-height: 0.78;
    padding: 0.1rem 0.6rem 0 0;
    color: var(--color-verde-dark);
  }

  .prose-custom h2 {
    font-size: 1.875rem;
    font-weight: 800;
    color: var(--color-negro);
    line-height: 1.2;
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    scroll-margin-top: 6rem;
  }

  .prose-custom h3 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-negro);
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 6rem;
  }

  .prose-custom p {
    margin-bottom: 1.25rem;
  }

  .prose-custom ul, .prose-custom ol {
    margin: 1.25rem 0 1.5rem 1.5rem;
  }

  .prose-custom ul li {
    list-style: none;
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.5rem;
  }

  .prose-custom ul li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-verde-dark);
    font-weight: 700;
  }

  .prose-custom ol {
    counter-reset: ol-counter;
    list-style: none;
  }

  .prose-custom ol li {
    counter-increment: ol-counter;
    padding-left: 2rem;
    position: relative;
    margin-bottom: 0.5rem;
  }

  .prose-custom ol li::before {
    content: counter(ol-counter, decimal-leading-zero);
    position: absolute;
    left: 0;
    color: var(--color-verde-dark);
    font-weight: 700;
    font-family: var(--font-display);
  }

  .prose-custom strong {
    color: var(--color-negro);
    font-weight: 700;
  }

  .prose-custom a {
    color: var(--color-negro);
    text-decoration: underline;
    text-decoration-color: var(--color-verde);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  .prose-custom a:hover {
    color: var(--color-verde-dark);
  }

  .prose-custom blockquote {
    border-left: 4px solid var(--color-verde);
    padding-left: 1.5rem;
    margin: 2.5rem 0;
    font-style: italic;
    font-size: 1.4rem;
    line-height: 1.45;
    color: var(--color-negro);
    font-weight: 500;
  }

  /* Destacado / aside editorial */
  .prose-custom .callout {
    background: #F4F6EE;
    border: 1px solid #DDE7C5;
    border-left: 4px solid var(--color-verde);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin: 2.25rem 0;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-negro);
  }

  .prose-custom .callout p:last-child { margin-bottom: 0; }

  .prose-custom .callout .callout-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--color-verde-dark);
    margin-bottom: 0.4rem;
  }

  /* Figuras con pie de foto */
  .prose-custom figure {
    margin: 2.5rem 0;
  }

  .prose-custom figure img {
    margin: 0;
  }

  .prose-custom figcaption {
    margin-top: 0.6rem;
    font-size: 0.875rem;
    color: #6B6B6B;
    text-align: center;
    line-height: 1.4;
  }

  .prose-custom img {
    border-radius: 6px;
    margin: 2rem 0;
    max-width: 100%;
    height: auto;
  }

  .prose-custom code {
    background: #F4F4F0;
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    font-size: 0.95em;
  }

  .prose-custom pre {
    background: var(--color-negro);
    color: var(--color-blanco);
    padding: 1.25rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose-custom pre code {
    background: transparent;
    padding: 0;
  }

  .prose-custom hr {
    border: none;
    border-top: 1px solid var(--color-borde);
    margin: 3rem 0;
  }

  /* Índice de contenidos */
  .toc-box {
    background: #FAFAF7;
    border: 1px solid var(--color-borde);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }

  .toc-title {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-negro);
    margin-bottom: 0.75rem;
  }

  .toc-box ol {
    list-style: none;
    counter-reset: toc;
    margin: 0;
    padding: 0;
  }

  .toc-box li {
    counter-increment: toc;
    margin-bottom: 0.4rem;
    padding-left: 1.75rem;
    position: relative;
  }

  .toc-box li::before {
    content: counter(toc, decimal-leading-zero);
    position: absolute;
    left: 0;
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--color-verde-dark);
  }

  .toc-box a {
    color: var(--color-gris-texto);
    text-decoration: none;
    font-size: 0.975rem;
    transition: color 0.2s ease;
  }

  .toc-box a:hover {
    color: var(--color-verde-dark);
    text-decoration: underline;
    text-decoration-color: var(--color-verde);
  }

  /* Botones de compartir */
  .share-btn {
    display: inline-block;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--color-borde);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-negro);
    background: #FFFFFF;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .share-btn:hover {
    background: var(--color-verde);
    border-color: var(--color-verde);
    color: var(--color-negro);
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
