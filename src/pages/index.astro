---
import BaseLayout from '../layouts/BaseLayout.astro';
import Monograma from '../components/Monograma.astro';
import Schema from '../components/Schema.astro';
import DiagnosticoIA from '../components/DiagnosticoIA.astro';

const pilares = [
  {
    num: '01',
    tag: 'ESTRATEGIA',
    titulo: 'Comunicación con eje, no con calendario.',
    body: 'Cada acción parte de un objetivo de negocio. La creatividad sin estrategia es decoración.',
  },
  {
    num: '02',
    tag: 'SOSTENIBILIDAD',
    titulo: 'Sostenibilidad que demuestra.',
    body: 'Datos, métricas, auditorías. Lo que no se puede medir, no se debería contar.',
  },
  {
    num: '03',
    tag: 'INTELIGENCIA',
    titulo: 'IA donde ahorra horas o multiplica salidas.',
    body: 'Implantación concreta donde ahorra trabajo o multiplica capacidad. Sin postureo.',
  },
];

// Qué hago — oferta escaneable enlazada a las páginas de servicio.
const servicios = [
  {
    titulo: 'Comunicación estratégica',
    body: 'Del relato a la decisión. Dirección de comunicación con eje, no con calendario.',
    href: '/comunicacion-estrategica/',
  },
  {
    titulo: 'Comunicación de sostenibilidad y ESG',
    body: 'Confianza sin greenwashing. Datos ESG y memorias CSRD traducidos a mensajes que se entienden y se creen.',
    href: '/comunicacion-sostenibilidad/',
  },
  {
    titulo: 'IA aplicada a la comunicación',
    body: 'Adopción con criterio: dónde la IA ahorra horas o multiplica capacidad, sin perder la voz.',
    href: '/ia-comunicacion/',
  },
  {
    titulo: 'Automatización para comunicación',
    body: 'Lo repetitivo, a la máquina. Tu equipo, a lo estratégico. Automatización con control de calidad.',
    href: '/automatizacion-comunicacion/',
  },
  {
    titulo: 'Formación en IA para comunicación',
    body: 'Que tu equipo use la IA con criterio y autonomía. Formación práctica que aterriza en el día a día.',
    href: '/formacion-ia-comunicacion/',
  },
];

const audiencia = [
  { tag: 'Empresas', body: 'que quieren comunicar con criterio y diferenciarse.' },
  { tag: 'Instituciones', body: 'que rinden cuentas y necesitan explicar bien lo público.' },
  { tag: 'Equipos de comunicación', body: 'que quieren incorporar sostenibilidad e IA sin perder la voz.' },
  { tag: 'Dirección', body: 'que decide mejor cuando la comunicación tiene eje.' },
];

const manifiestoLineas = [
  '"Las organizaciones que mejor comunican',
  'son las que mejor deciden.',
  'Las que mejor deciden son las que han convertido',
  'la sostenibilidad en ventaja',
  'y la IA en herramienta.',
  'Mi trabajo es conectar esas tres palancas',
  'para que el resultado se vea en negocio,',
  'no solo en intenciones."',
];

// Sectores donde trabajo — prueba de confianza por contexto, sin nombrar clientes.
const sectores = [
  { tag: 'Construcción', body: 'Un sector bajo escrutinio ambiental que necesita comunicar sostenibilidad sin exponerse.' },
  { tag: 'Energía', body: 'Datos ESG y transición que hay que traducir a un relato creíble y defendible.' },
  { tag: 'Institucional', body: 'Lo público explicado con claridad, rindiendo cuentas sin perder rigor.' },
  { tag: 'Comunicación', body: 'Equipos y agencias que incorporan IA y criterio a sus procesos.' },
];

// Situaciones tipo — casos anónimos representativos (problema → enfoque → resultado).
// Cualitativos a propósito: nada de métricas inventadas.
const situaciones = [
  {
    sector: 'Construcción',
    problema: 'Una constructora de tamaño medio quería comunicar su sostenibilidad, pero temía las acusaciones de greenwashing.',
    enfoque: 'Ordené el relato sobre evidencias y un mapa de riesgos reputacionales.',
    resultado: 'Mensajes defendibles ante clientes, administración y medios.',
  },
  {
    sector: 'Energía',
    problema: 'Una empresa del sector energético tenía datos ESG complejos y una memoria difícil de explicar.',
    enfoque: 'Traduje los datos a una narrativa con criterios de evidencia y un plan de contenidos.',
    resultado: 'Una historia de sostenibilidad que se entiende y se sostiene.',
  },
  {
    sector: 'Institucional',
    problema: 'Un organismo público debía explicar un proyecto ambiental técnico a una ciudadanía no experta.',
    enfoque: 'Definí el eje del mensaje y los materiales para distintos públicos.',
    resultado: 'Comunicación clara que rinde cuentas sin renunciar al rigor.',
  },
  {
    sector: 'Comunicación',
    problema: 'Un equipo de comunicación estaba saturado de tareas repetitivas y temía perder el control con la IA.',
    enfoque: 'Decidimos qué automatizar, qué no tocar y una política interna de uso.',
    resultado: 'Más tiempo para lo estratégico, sin perder la voz de la organización.',
  },
];
---

<BaseLayout
  title="Javi Cebrián · Director de Comunicación con sostenibilidad e IA"
  seoTitle="Comunicación, sostenibilidad e IA · Javi Cebrián"
  description="Comunicación que mueve organizaciones. Con sostenibilidad e IA como ventaja. Director de Comunicación y Desarrollo de Negocio en Imedes."
>
  <Schema type="Person" />
  <Schema type="ProfessionalService" />

  <!-- HERO MAXIMALISTA -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7] relative overflow-hidden min-h-[92vh] flex items-end pb-12">
    <!-- Monograma decorativo de fondo (parallax) -->
    <div class="absolute right-[-10%] top-[-8%] w-[85vh] h-[85vh] opacity-[0.05] pointer-events-none" data-parallax="0.12">
      <Monograma size={1200} variant="blanco" withAccent={false} class="w-full h-full" />
    </div>

    <!-- Meta-strip arriba -->
    <div class="container-wide absolute top-0 left-0 right-0 z-10">
      <div class="meta-strip">
        <span>VOL. 01 · JAVI · CEBRIÁN · 2026</span>
        <span class="inline-flex gap-6 flex-wrap">
          <span><span class="dot-on">●</span> DISPONIBLE Q2</span>
          <span class="hidden sm:inline">VALENCIA · 39.47°N 0.37°W</span>
        </span>
      </div>
    </div>

    <!-- Contenido principal -->
    <div class="container-wide w-full relative z-5">
      <span class="acento-verde block mb-6" data-mask-up></span>
      <h1 class="m-0 font-extrabold text-[#FAFAF7] leading-[0.85] tracking-[-0.025em]" style="font-size: clamp(3.5rem, 14vw, 16rem);">
        <span data-mask-up data-delay="0" class="block">COMUNICA.</span>
        <span data-mask-up data-delay="140" class="block text-[#8DBE3F]">DECIDE.</span>
        <span data-mask-up data-delay="280" class="block">MULTIPLICA.</span>
      </h1>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-end mt-10">
        <div class="md:col-span-7" data-reveal data-delay="500">
          <p class="text-base md:text-lg leading-relaxed text-[#FAFAF7]/85 max-w-2xl">
            Ayudo a organizaciones y equipos directivos a convertir <span class="text-[#8DBE3F] font-semibold">comunicación estratégica, sostenibilidad e inteligencia artificial</span> en decisiones de negocio, no solo en intenciones. Director de Comunicación y Desarrollo de Negocio en Imedes.
          </p>
          <div class="flex gap-3 mt-8 flex-wrap items-center">
            <a href="#diagnostico" data-magnetic="0.3" data-ga-event="cta_click" data-ga-label="hero_diagnostico" class="inline-flex items-center gap-2 px-8 py-4 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
              Haz tu diagnóstico IA · 2 min →
            </a>
            <a href="/trabajemos-juntos/" data-magnetic="0.2" data-ga-event="cta_click" data-ga-label="hero_empieza_proyecto" class="inline-flex items-center gap-2 px-8 py-4 border border-[#FAFAF7]/20 text-[#FAFAF7] font-medium text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7]/5 transition-colors">
              Empieza el proyecto
            </a>
            <a href="/servicios/" data-ga-event="cta_click" data-ga-label="hero_ver_servicios" class="text-sm text-[#A0A0A0] underline-offset-4 hover:text-[#FAFAF7] hover:underline transition-colors ml-1">
              o ver servicios
            </a>
          </div>
        </div>
      </div>
      <div class="absolute bottom-[-1rem] right-10 font-display text-xs text-[#A0A0A0] hidden md:block">SCROLL ↓</div>
    </div>
  </section>

  <!-- TAPE — banda con manifiesto en marquee -->
  <div class="tape" aria-hidden="true">
    <div class="tape-track">
      {Array.from({ length: 8 }).map(() => (
        <span>COMUNICACIÓN QUE MUEVE <span class="dot">·</span> SOSTENIBILIDAD QUE DEMUESTRA <span class="dot">·</span> IA QUE MULTIPLICA <span class="dot">·</span></span>
      ))}
    </div>
  </div>

  <!-- MANIFIESTO sticky + line-reveal -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]">
    <div class="container-wide py-24 md:py-32">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-16 items-start">
        <div class="md:sticky md:top-28">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#8DBE3F] m-0">§ 01</p>
          <p class="font-display text-xs text-[#A0A0A0] mt-2">MANIFIESTO</p>
        </div>
        <blockquote class="md:col-span-3 m-0 italic font-medium leading-snug" style="font-size: clamp(1.75rem, 4vw, 3.5rem); letter-spacing: -0.025em;">
          {manifiestoLineas.map((linea, i) => (
            <span data-line-reveal>{linea}{i < manifiestoLineas.length - 1 ? ' ' : ''}</span>
          ))}
        </blockquote>
      </div>
    </div>
  </section>

  <!-- PILARES FULLSCREEN ALTERNADOS -->
  {pilares.map((p, i) => {
    const isLight = i % 2 === 0;
    const bg = isLight ? '#FAFAF7' : '#1A1A1A';
    const fg = isLight ? '#1A1A1A' : '#FAFAF7';
    const fgSoft = isLight ? '#3D3D3D' : '#A0A0A0';
    const outlineClass = isLight ? 'text-outline-dark' : 'text-outline-light';
    return (
      <section style={{ background: bg, color: fg, borderTop: '1px solid rgba(0,0,0,0.06)' }}>
        <div class="container-wide py-24 md:py-32">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
            <div class="md:col-span-4">
              <p class={`font-display text-base m-0 ${outlineClass}`} style={`font-family: var(--font-display); font-size: clamp(7rem, 16vw, 14rem); line-height: 0.85; letter-spacing: -0.02em;`} data-mask-up>
                <span>{p.num}</span>
              </p>
              <p class="font-display text-xs mt-4" style={`color: ${isLight ? '#467010' : '#8DBE3F'};`}>{p.tag}</p>
            </div>
            <div class="md:col-span-8 pt-4">
              <h2 class="font-extrabold m-0 leading-[1.05] tracking-[-0.04em]" style={`font-size: clamp(2rem, 4vw, 4rem); max-width: 22ch; color: ${fg};`} data-mask-up data-delay="100">
                <span>{p.titulo}</span>
              </h2>
              <p class="mt-8 text-lg md:text-xl leading-relaxed max-w-2xl" style={`color: ${fgSoft};`} data-reveal data-delay="200">
                {p.body}
              </p>
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- QUÉ HAGO + PARA QUIÉN -->
  <section class="bg-[#FAFAF7] text-[#1A1A1A]" style="border-top: 1px solid rgba(0,0,0,0.06);">
    <div class="container-wide py-24 md:py-32">
      <!-- Qué hago -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4 md:sticky md:top-28">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#467010] m-0">§ 04</p>
          <p class="font-display text-xs text-[#6B6B6B] mt-2">QUÉ HAGO</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 3rem); max-width: 14ch;" data-mask-up>
            <span>Tres palancas. Un mismo criterio.</span>
          </h2>
        </div>
        <div class="md:col-span-8">
          {servicios.map((s, i) => (
            <a href={s.href} class="group block py-7" style={i > 0 ? 'border-top: 1px solid #E5E5E0;' : ''} data-reveal data-delay={`${i * 100}`} data-ga-event="service_click" data-ga-label={s.titulo}>
              <h3 class="font-extrabold m-0 leading-tight tracking-[-0.02em] flex items-center gap-3 group-hover:text-[#467010] transition-colors" style="font-size: clamp(1.35rem, 2.5vw, 1.9rem);">
                <span>{s.titulo}</span>
                <span class="text-[#8DBE3F] text-xl opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">→</span>
              </h3>
              <p class="mt-3 text-base md:text-lg leading-relaxed text-[#3D3D3D] max-w-2xl">{s.body}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Para quién -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start mt-20 md:mt-28">
        <div class="md:col-span-4">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#467010] m-0">§ 05</p>
          <p class="font-display text-xs text-[#6B6B6B] mt-2">PARA QUIÉN</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 3rem); max-width: 12ch;" data-mask-up>
            <span>Trabajo con quien decide.</span>
          </h2>
        </div>
        <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-8">
          {audiencia.map((a, i) => (
            <div data-reveal data-delay={`${i * 80}`}>
              <p class="font-display text-sm text-[#1A1A1A] m-0 tracking-wide">{a.tag}</p>
              <p class="mt-2 text-base leading-relaxed text-[#3D3D3D]">{a.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CONFIANZA — sectores + situaciones tipo anonimizadas -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container-wide py-24 md:py-32">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4 md:sticky md:top-28">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#8DBE3F] m-0">§ 06</p>
          <p class="font-display text-xs text-[#A0A0A0] mt-2">DÓNDE TRABAJO</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 3rem); max-width: 16ch;" data-mask-up>
            <span>Trabajo donde la comunicación tiene consecuencias.</span>
          </h2>
          <p class="mt-6 text-base leading-relaxed text-[#A0A0A0] max-w-md" data-reveal data-delay="120">
            Sectores con escrutinio, datos que demostrar y públicos exigentes. Donde comunicar bien no es estética: es reputación, confianza y negocio.
          </p>
        </div>

        <div class="md:col-span-8">
          <!-- Sectores -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-8 pb-14 mb-14 border-b border-white/10">
            {sectores.map((s, i) => (
              <div data-reveal data-delay={`${i * 80}`}>
                <p class="font-display text-sm text-[#8DBE3F] m-0 tracking-wide">{s.tag}</p>
                <p class="mt-2 text-base leading-relaxed text-[#A0A0A0]">{s.body}</p>
              </div>
            ))}
          </div>

          <!-- Situaciones tipo -->
          <p class="font-display text-xs text-[#A0A0A0] mb-8" data-reveal>SITUACIONES TIPO</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {situaciones.map((c, i) => (
              <div class="p-7 rounded-lg bg-[#FAFAF7]/[0.03] border border-[#FAFAF7]/10" data-reveal data-delay={`${i * 90}`}>
                <p class="font-display text-xs text-[#8DBE3F] tracking-wide m-0">{c.sector}</p>
                <p class="mt-4 text-base leading-relaxed text-[#FAFAF7]/90">{c.problema}</p>
                <p class="mt-3 text-sm leading-relaxed text-[#A0A0A0]"><span class="text-[#8DBE3F]">→</span> {c.enfoque}</p>
                <p class="mt-4 pt-4 border-t border-white/10 text-sm font-semibold leading-relaxed text-[#FAFAF7]">{c.resultado}</p>
              </div>
            ))}
          </div>

          <p class="mt-8 text-xs text-[#6B6B6B] max-w-2xl" data-reveal>
            Casos representativos, anonimizados para proteger a cada cliente. Si quieres referencias concretas, te las doy en una conversación.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- DIAGNÓSTICO IA — gancho interactivo (capta a Notion + WhatsApp) -->
  <DiagnosticoIA />

  <!-- TAPE inferior -->
  <div class="tape" aria-hidden="true">
    <div class="tape-track">
      {Array.from({ length: 8 }).map(() => (
        <span>HABLAMOS <span class="dot">·</span> EN MENOS DE 48 HORAS <span class="dot">·</span> SIN EMBUDOS <span class="dot">·</span></span>
      ))}
    </div>
  </div>

  <!-- CTA FINAL -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]">
    <div class="container-wide py-24 md:py-32">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-end">
        <div class="md:col-span-7">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#8DBE3F] mb-4" data-reveal>§ HABLAMOS</p>
          <h2 class="font-extrabold tracking-[-0.025em] leading-[0.85] m-0" style="font-size: clamp(3rem, 9vw, 9rem);">
            <span data-mask-up class="block">HABLAMOS.</span>
          </h2>
          <p class="mt-8 text-lg md:text-xl text-[#A0A0A0] max-w-xl leading-relaxed" data-reveal data-delay="200">
            Cuéntame tu reto de comunicación. Si hay encaje, te digo cómo lo abordaría y qué obtienes. Sin embudos y con respuesta en menos de 48 horas.
          </p>
        </div>
        <div class="md:col-span-5 md:text-right" data-reveal data-delay="300">
          <a href="/trabajemos-juntos/" data-magnetic="0.3" data-ga-event="cta_click" data-ga-label="final_cuentame_reto" class="inline-flex items-center gap-2 px-10 py-5 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
            Cuéntame tu reto →
          </a>
          <p class="mt-6 text-xs text-[#A0A0A0]">
            ¿Solo una duda rápida? <a href="/contacto/" data-ga-event="cta_click" data-ga-label="final_contacto" class="text-[#FAFAF7] hover:text-[#8DBE3F] transition-colors">Escríbeme aquí</a> · <a href="mailto:jcebrian@grupimedes.com" data-ga-event="contact_click" data-ga-label="email" class="text-[#FAFAF7] hover:text-[#8DBE3F] transition-colors">jcebrian@grupimedes.com</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
