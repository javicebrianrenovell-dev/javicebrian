---
import BaseLayout from '../layouts/BaseLayout.astro';
import Monograma from '../components/Monograma.astro';

const pilares = [
  {
    num: '01',
    titulo: 'Estrategia que comunica.',
    texto: 'Cada acción parte de un objetivo de negocio. La creatividad sin estrategia es decoración.',
  },
  {
    num: '02',
    titulo: 'Sostenibilidad que demuestra.',
    texto: 'Datos, métricas, auditorías. Lo que no se puede medir, no se debería contar.',
  },
  {
    num: '03',
    titulo: 'IA que multiplica.',
    texto: 'Implantación concreta donde ahorra trabajo o multiplica capacidad. Sin postureo.',
  },
];
---

<BaseLayout
  title="Javi Cebrián · Director de Comunicación con sostenibilidad e IA"
  description="Comunicación que mueve organizaciones. Con sostenibilidad e IA como ventaja. Director de Comunicación y Desarrollo de Negocio en Imedes."
>
  <!-- HERO -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7] relative overflow-hidden">
    <div class="container-base py-24 md:py-36 relative z-10">
      <div class="acento-verde mb-8"></div>
      <p class="font-display text-sm text-[#8DBE3F] mb-6">JAVI CEBRIÁN</p>
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold leading-[1.05] tracking-tighter max-w-5xl">
        Comunicación que mueve organizaciones.
        <span class="text-[#8DBE3F] block mt-2">Con sostenibilidad e IA como ventaja.</span>
      </h1>
      <p class="mt-10 text-lg md:text-xl text-[#A0A0A0] max-w-2xl leading-relaxed">
        Director de Comunicación y Desarrollo de Negocio. Trabajo con organizaciones que quieren convertir reputación, sostenibilidad e IA en una ventaja real de negocio.
      </p>
      <div class="mt-12 flex flex-wrap gap-4">
        <a href="/contacto/" class="inline-flex items-center gap-2 px-8 py-4 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
          Hablamos →
        </a>
        <a href="/quien-soy/" class="inline-flex items-center gap-2 px-8 py-4 border border-[#FAFAF7]/20 text-[#FAFAF7] font-medium text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7]/5 transition-colors">
          Quién soy
        </a>
      </div>
    </div>
    <!-- Monograma decorativo -->
    <div class="absolute right-[-80px] bottom-[-80px] opacity-[0.04] pointer-events-none hidden md:block">
      <Monograma size={500} variant="blanco" withAccent={false} />
    </div>
  </section>

  <!-- TRES PILARES -->
  <section class="container-base py-24 md:py-32">
    <div class="acento-verde mb-8"></div>
    <h2 class="font-display text-sm text-[#1A1A1A] mb-3">MANIFIESTO</h2>
    <p class="text-3xl md:text-4xl font-bold tracking-tight text-[#1A1A1A] max-w-3xl mb-16 leading-tight">
      Estrategia que comunica.<br>
      Sostenibilidad que demuestra.<br>
      IA que multiplica.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {pilares.map(({ num, titulo, texto }) => (
        <div class="border-t border-[#1A1A1A] pt-6">
          <p class="font-display text-2xl text-[#8DBE3F] mb-3">{num}</p>
          <h3 class="text-xl font-bold text-[#1A1A1A] mb-3 leading-tight">{titulo}</h3>
          <p class="text-base text-[#3D3D3D] leading-relaxed">{texto}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- MANIFIESTO NARRATIVO -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]">
    <div class="container-base py-24 md:py-32">
      <div class="max-w-4xl">
        <div class="acento-verde mb-8"></div>
        <p class="font-display text-sm text-[#8DBE3F] mb-6">POR QUÉ TRABAJO ASÍ</p>
        <blockquote class="text-2xl md:text-3xl font-medium leading-snug italic">
          "Las organizaciones que mejor comunican son las que mejor deciden. Las que mejor deciden son las que han convertido la sostenibilidad en ventaja y la IA en herramienta. Mi trabajo es conectar esas tres palancas para que el resultado se vea en negocio, no solo en intenciones."
        </blockquote>
        <p class="mt-10 font-display text-xs text-[#A0A0A0] tracking-widest">— JAVI CEBRIÁN</p>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="container-base py-24 md:py-32 text-center">
    <div class="acento-verde mx-auto mb-8"></div>
    <h2 class="text-4xl md:text-6xl font-extrabold text-[#1A1A1A] tracking-tighter mb-6">
      Hablamos.
    </h2>
    <p class="text-lg text-[#3D3D3D] max-w-xl mx-auto mb-10">
      Si tu organización quiere comunicar con criterio y aprovechar sostenibilidad e IA como ventaja real, este es el sitio para empezar la conversación.
    </p>
    <a href="/contacto/" class="inline-flex items-center gap-2 px-10 py-5 bg-[#1A1A1A] text-[#FAFAF7] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#8DBE3F] hover:text-[#1A1A1A] transition-colors">
      Contacta →
    </a>
  </section>
</BaseLayout>
