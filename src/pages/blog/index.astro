---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= new Date()))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const categoriaLabel: Record<string, string> = {
  comunicacion: 'Comunicación',
  sostenibilidad: 'Sostenibilidad',
  ia: 'Inteligencia Artificial',
  herramientas: 'Herramientas',
};

const dateFormatter = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title="Blog — Javi Cebrián"
  description="Reflexiones con criterio sobre comunicación, sostenibilidad e IA aplicadas al negocio. Sin postureo, con argumentos."
>
  <!-- HERO -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7] relative overflow-hidden">
    <div class="container-wide py-20 md:py-24">
      <span class="acento-verde block mb-6" data-mask-up></span>
      <p class="font-display text-xs text-[#8DBE3F] mb-4" data-mask-up data-delay="80">§ NOTAS</p>
      <h1 class="font-extrabold leading-[0.85] tracking-[-0.02em] m-0" style="font-family: var(--font-display); font-size: clamp(3.5rem, 12vw, 12rem);">
        <span data-mask-up data-delay="0" class="block">DIARIO</span>
        <span data-mask-up data-delay="140" class="block text-[#8DBE3F]">EDITORIAL.</span>
      </h1>
      <p class="mt-10 text-base text-[#A0A0A0] max-w-2xl" data-reveal data-delay="280">
        {posts.length} artículos sobre comunicación, sostenibilidad e IA. Sin postureo, con argumentos.
      </p>
    </div>
  </section>

  <!-- LISTADO EDITORIAL — fila por fila con número grande -->
  <section class="container-wide py-16 md:py-24">
    <div>
      {posts.map((post, i) => (
        <article data-reveal data-delay={i * 60} class="group">
          <a
            href={`/blog/${post.slug}/`}
            class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 items-start py-8 md:py-10 border-t border-[#1A1A1A] no-underline text-inherit transition-colors hover:bg-[#8DBE3F]/5"
          >
            <div class="md:col-span-1">
              <p class="font-display text-3xl md:text-4xl text-[#8DBE3F] m-0 leading-none" style="letter-spacing: 0.02em;">
                {String(posts.length - i).padStart(3, '0')}
              </p>
            </div>
            <div class="md:col-span-2">
              <p class="font-display text-xs text-[#1A1A1A] m-0">{categoriaLabel[post.data.category]}</p>
              <p class="text-xs text-[#6B6B6B] mt-1.5">
                {dateFormatter.format(post.data.pubDate)}
              </p>
            </div>
            <div class="md:col-span-7">
              <h2 class="font-extrabold tracking-[-0.03em] leading-[1.1] text-[#1A1A1A] m-0 transition-colors group-hover:text-[#8DBE3F]" style="font-size: clamp(1.5rem, 2.5vw, 2.25rem);">
                {post.data.title}
              </h2>
              <p class="mt-3 text-base text-[#3D3D3D] leading-relaxed max-w-2xl">
                {post.data.description}
              </p>
            </div>
            <div class="md:col-span-2 md:text-right">
              {post.data.heroImage ? (
                <img
                  src={post.data.heroImage}
                  alt={`Imagen del artículo: ${post.data.title}`}
                  class="w-full md:w-32 md:h-24 object-cover rounded-md transition-transform duration-700 group-hover:scale-105 ml-auto"
                  loading="lazy"
                />
              ) : (
                <span class="text-2xl text-[#1A1A1A] inline-block transition-transform group-hover:translate-x-1">↗</span>
              )}
            </div>
          </a>
        </article>
      ))}
      <div class="border-t border-[#1A1A1A]"></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]">
    <div class="container-base py-20 md:py-24 text-center">
      <div class="acento-verde mx-auto mb-8" data-reveal></div>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tighter mb-6" data-reveal>
        ¿Algún tema que quieras leer?
      </h2>
      <p class="text-lg text-[#A0A0A0] max-w-xl mx-auto mb-10" data-reveal>
        Escríbeme con la pregunta. Si veo que merece artículo, lo publico aquí con tu agradecimiento incluido.
      </p>
      <a href="/contacto/" data-magnetic="0.3" class="inline-flex items-center gap-2 px-10 py-5 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
        Sugiérelo →
      </a>
    </div>
  </section>
</BaseLayout>
