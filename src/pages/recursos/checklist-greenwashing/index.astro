---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const incluye = [
  { num: '01', t: 'Antes de comunicar', d: 'Los cuatro filtros que separan un compromiso real de un adorno verde.' },
  { num: '02', t: 'Las palabras', d: 'Qué términos definir, cuáles evitar y dónde se esconde el dato engañoso.' },
  { num: '03', t: 'Las pruebas', d: 'Cómo sostener cada afirmación con fuente, método y fecha.' },
  { num: '04', t: 'El equilibrio', d: 'Reconocer lo que aún no haces bien sin debilitar tu mensaje.' },
  { num: '05', t: 'El riesgo', d: 'El test final antes de publicar: ¿resiste a un periodista o a un regulador?' },
];

const paraQuien = [
  'Equipos de comunicación que reportan sostenibilidad o ESG.',
  'Direcciones que firman mensajes ambientales y asumen el riesgo.',
  'Empresas con presión CSRD que no quieren pasarse ni quedarse cortas.',
  'Agencias y consultoras que asesoran a clientes con agenda verde.',
];
---

<BaseLayout
  title="Checklist para comunicar sostenibilidad sin greenwashing"
  seoTitle="Checklist anti-greenwashing · Javi Cebrián"
  description="20 controles en 5 bloques para que tu comunicación de sostenibilidad sea creíble, útil y defendible. Descárgalo gratis."
>
  <!-- HERO -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7] relative overflow-hidden">
    <div class="container-wide py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center">
        <div class="md:col-span-7">
          <span class="acento-verde block mb-6" data-mask-up></span>
          <p class="font-display text-xs text-[#8DBE3F] mb-4" data-mask-up data-delay="80">RECURSO GRATUITO</p>
          <h1 class="font-extrabold leading-[0.9] tracking-[-0.02em] m-0" style="font-size: clamp(2.5rem, 7vw, 5rem);">
            <span data-mask-up data-delay="0" class="block">Comunica sostenibilidad</span>
            <span data-mask-up data-delay="140" class="block text-[#8DBE3F]">sin greenwashing.</span>
          </h1>
          <p class="mt-8 text-base md:text-lg text-[#A0A0A0] max-w-xl leading-relaxed" data-reveal data-delay="280">
            Un checklist de <strong class="text-[#FAFAF7]">20 controles en 5 bloques</strong>. Pásalo antes de publicar cualquier mensaje de sostenibilidad y sabrás si es defendible o si te estás exponiendo. Sin teoría: operativo y al grano.
          </p>
        </div>

        <!-- FORM -->
        <div class="md:col-span-5">
          <div class="bg-[#FAFAF7] text-[#1A1A1A] rounded-lg p-7 md:p-8">
            <p class="font-display text-xs text-[#467010]">DESCARGA INMEDIATA</p>
            <p class="text-xl font-extrabold tracking-tight mt-2 mb-6">Déjame tu email y es tuyo.</p>

            <form id="resource-form" novalidate data-resource="/recursos/checklist-greenwashing/checklist/" data-recurso="Checklist greenwashing">
              <!-- Honeypot -->
              <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;" />

              <label for="rg-email" class="block text-sm font-bold mb-2">Email *</label>
              <input id="rg-email" name="email" type="email" required autocomplete="email" class="w-full px-4 py-3 border-[1.5px] border-[#E5E5E0] rounded-md bg-white text-[#1A1A1A] focus:border-[#8DBE3F] focus:outline-none" />

              <div class="flex items-start gap-3 mt-4">
                <input id="rg-rgpd" name="rgpd" type="checkbox" required class="mt-1 accent-[#8DBE3F]" />
                <label for="rg-rgpd" class="text-xs text-[#3D3D3D] leading-relaxed">
                  Acepto la <a href="/politica-de-privacidad/" class="underline hover:text-[#8DBE3F]">política de privacidad</a>. Usaré tu email solo para enviarte el recurso y, como mucho, alguna idea útil. Cero spam, baja cuando quieras.
                </label>
              </div>

              <button id="rg-submit" type="submit" class="w-full mt-6 px-6 py-3.5 bg-[#1A1A1A] text-[#FAFAF7] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#8DBE3F] hover:text-[#1A1A1A] transition-colors">
                Quiero el checklist →
              </button>

              <div id="rg-feedback" class="hidden" role="status" aria-live="polite"></div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- QUÉ INCLUYE -->
  <section class="bg-[#FAFAF7] text-[#1A1A1A]">
    <div class="container-wide py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#467010] m-0">§ 01</p>
          <p class="font-display text-xs text-[#6B6B6B] mt-2">QUÉ INCLUYE</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 2.75rem); max-width: 14ch;" data-mask-up>
            <span>Cinco bloques. Veinte controles.</span>
          </h2>
        </div>
        <div class="md:col-span-8">
          {incluye.map((b, i) => (
            <div class="py-6 grid grid-cols-1 sm:grid-cols-12 gap-4" style={i > 0 ? 'border-top: 1px solid #E5E5E0;' : ''} data-reveal data-delay={`${i * 80}`}>
              <p class="sm:col-span-2 font-display text-3xl text-[#8DBE3F] m-0 leading-none">{b.num}</p>
              <div class="sm:col-span-10">
                <h3 class="font-extrabold m-0 leading-tight tracking-[-0.02em]" style="font-size: clamp(1.2rem, 2.2vw, 1.5rem);">{b.t}</h3>
                <p class="mt-2 text-base md:text-lg leading-relaxed text-[#3D3D3D] max-w-2xl">{b.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PARA QUIÉN -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container-wide py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#8DBE3F] m-0">§ 02</p>
          <p class="font-display text-xs text-[#A0A0A0] mt-2">PARA QUIÉN</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 2.75rem); max-width: 12ch;" data-mask-up>
            <span>Si firmas mensajes de sostenibilidad, es para ti.</span>
          </h2>
        </div>
        <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-7">
          {paraQuien.map((p, i) => (
            <div class="flex gap-3" data-reveal data-delay={`${i * 70}`}>
              <span class="text-[#8DBE3F] font-bold">→</span>
              <p class="m-0 text-base md:text-lg leading-relaxed text-[#A0A0A0]">{p}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    import { initResourceGate } from '../../../scripts/resource-gate';
    initResourceGate();
    document.addEventListener('astro:page-load', initResourceGate);
  </script>
</BaseLayout>
