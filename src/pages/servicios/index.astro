---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const servicios = (await getCollection('services', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

// Reencuadre por necesidad del cliente: cada servicio responde a un "necesito…".
const necesidadPorSlug: Record<string, string> = {
  'comunicacion-estrategica': 'Necesito ordenar mi comunicación y darle dirección.',
  'comunicacion-sostenibilidad': 'Necesito comunicar mi sostenibilidad sin caer en greenwashing.',
  'ia-comunicacion': 'Necesito introducir la IA en mi equipo con criterio.',
  'automatizacion-comunicacion': 'Necesito automatizar procesos repetitivos y ganar tiempo.',
  'formacion-ia-comunicacion': 'Necesito formar a mi equipo en IA sin perder criterio.',
};

// Cómo suelo trabajar — método transversal a todos los servicios.
const comoTrabajo = [
  { num: '01', titulo: 'Diagnóstico', body: 'Escucho antes de proponer. Qué dices, qué dicen de ti y dónde está el hueco.' },
  { num: '02', titulo: 'Foco estratégico', body: 'Definimos el eje y las prioridades. Menos frentes, mejor defendidos.' },
  { num: '03', titulo: 'Plan de acción', body: 'Un plan con criterio, no un calendario lleno. Qué se hace, en qué orden y por qué.' },
  { num: '04', titulo: 'Ejecución y acompañamiento', body: 'Dirijo, acompaño o formo a tu equipo, según tu estructura. No te dejo solo en lo difícil.' },
  { num: '05', titulo: 'Medición', body: 'Definimos cómo se ve el avance. La comunicación rinde cuentas como cualquier otra área.' },
];

const paraQuien = [
  'Equipos directivos que deciden mejor cuando la comunicación tiene eje.',
  'Departamentos de comunicación que quieren incorporar sostenibilidad e IA sin perder la voz.',
  'Organizaciones con agenda ESG que necesitan comunicar con evidencia.',
  'Consultoras y agencias con procesos de comunicación intensivos.',
  'Instituciones que rinden cuentas y necesitan explicar bien lo público.',
];

const queNoHago = [
  'No vendo IA por moda: si no ahorra horas o no multiplica capacidad, no entra.',
  'No comunico sostenibilidad sin evidencias: lo que no se puede sostener, no se cuenta.',
  'No sustituyo estrategia por volumen: más publicaciones no es mejor comunicación.',
  'No te lleno el calendario: te ayudo a que cada acción tenga un porqué.',
];

// Puertas de entrada — ofertas acotadas para empezar con un encargo concreto.
// Sin precio: el presupuesto se cualifica en el formulario.
const puertas = [
  {
    num: '01',
    nombre: 'Diagnóstico de Comunicación con Criterio',
    para: 'Para quien necesita ordenar antes de invertir.',
    promesa: 'En una semana sabrás qué frena tu comunicación y qué pasos concretos dar para convertirla en reputación, eficiencia y negocio.',
    incluye: [
      'Sesión inicial para entender tu contexto.',
      'Revisión de comunicación, sostenibilidad, procesos y narrativa.',
      'Informe breve con prioridades.',
      'Sesión de devolución y plan de acción.',
    ],
  },
  {
    num: '02',
    nombre: 'IA para Comunicación sin Perder el Criterio',
    para: 'Para quien necesita activar a su equipo.',
    promesa: 'Que tu equipo use la IA para ahorrar tiempo y mejorar procesos sin poner en riesgo la voz de la organización.',
    incluye: [
      'Taller de 2, 4 u 8 horas con casos reales.',
      'Usos permitidos y usos que no tocaría.',
      'Procesos automatizables de tu día a día.',
      'Borrador de política interna y guía práctica.',
    ],
  },
  {
    num: '03',
    nombre: 'Comunicación de Sostenibilidad con Evidencia',
    para: 'Para quien tiene presión ESG o CSRD.',
    promesa: 'Convertir datos, compromisos y avances ambientales en comunicación creíble, útil y defendible. Sin greenwashing.',
    incluye: [
      'Revisión de mensajes y mapa de riesgos reputacionales.',
      'Narrativa de sostenibilidad con criterios de evidencia.',
      'Plan de contenidos o campaña.',
      'Pautas para sostener cada afirmación con datos.',
    ],
  },
];
---

<BaseLayout
  title="Servicios"
  seoTitle="Servicios de comunicación, sostenibilidad e IA"
  description="Comunicación estratégica, comunicación de sostenibilidad y ESG, IA aplicada, automatización y formación. Así puedo ayudar a tu organización."
>
  <!-- HERO -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7] pt-32 pb-16">
    <div class="container-wide">
      <span class="acento-verde block mb-6" data-mask-up></span>
      <p class="font-display text-xs text-[#8DBE3F] m-0" data-reveal>SERVICIOS</p>
      <h1
        class="m-0 font-extrabold leading-[0.9] tracking-[-0.03em] mt-4"
        style="font-size: clamp(2.5rem, 8vw, 6rem); max-width: 16ch;"
      >
        <span data-mask-up>Cómo puedo ayudarte.</span>
      </h1>
      <p class="mt-8 text-lg md:text-xl leading-relaxed text-[#FAFAF7]/85 max-w-2xl" data-reveal data-delay="200">
        Comunicación, sostenibilidad e inteligencia artificial no son tres disciplinas sueltas. Son tres
        palancas de la misma decisión: la comunicación ordena, la sostenibilidad da reputación y la IA
        multiplica productividad. Las trabajo juntas para que decidas mejor, expliques mejor y avances con dirección.
      </p>
    </div>
  </section>

  <!-- LISTA -->
  <section class="bg-[#FAFAF7] text-[#1A1A1A]">
    <div class="container-wide py-20 md:py-28">
      {servicios.map((s, i) => (
        <a
          href={`/${s.slug}/`}
          class="group grid grid-cols-1 md:grid-cols-12 gap-6 py-10"
          style={i > 0 ? 'border-top: 1px solid #E5E5E0;' : ''}
          data-reveal
          data-delay={`${i * 80}`}
        >
          <div class="md:col-span-1">
            <p class="font-display text-3xl text-[#8DBE3F] m-0 leading-none">0{i + 1}</p>
          </div>
          <div class="md:col-span-7">
            {necesidadPorSlug[s.slug] && (
              <p class="font-display text-xs text-[#467010] m-0 mb-2 tracking-wide">{necesidadPorSlug[s.slug]}</p>
            )}
            <h2 class="font-extrabold m-0 leading-tight tracking-[-0.02em] group-hover:text-[#467010] transition-colors" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
              {s.data.title}
            </h2>
            <p class="mt-3 text-base md:text-lg leading-relaxed text-[#3D3D3D] max-w-xl">{s.data.description}</p>
          </div>
          <div class="md:col-span-4 md:text-right flex md:block items-center">
            <span class="font-display text-sm text-[#1A1A1A] group-hover:text-[#467010] transition-colors inline-flex items-center gap-2">
              Ver servicio <span class="text-[#8DBE3F] group-hover:translate-x-1 transition-transform">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- POR DÓNDE EMPEZAR — puertas de entrada -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container-wide py-20 md:py-28">
      <div class="max-w-3xl">
        <span class="acento-verde block mb-6" data-reveal></span>
        <p class="font-display text-xs text-[#8DBE3F] m-0" data-reveal>POR DÓNDE EMPEZAR</p>
        <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 4vw, 3.25rem); max-width: 18ch;" data-mask-up>
          <span>Tres puertas de entrada. Un encargo concreto.</span>
        </h2>
        <p class="mt-6 text-base md:text-lg leading-relaxed text-[#A0A0A0] max-w-2xl" data-reveal data-delay="120">
          No hace falta contratar "comunicación estratégica" en abstracto. A veces se empieza por un problema concreto. Estas tres son las formas más rápidas de trabajar juntos.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-14">
        {puertas.map((p, i) => (
          <div class="flex flex-col p-7 rounded-lg bg-[#FAFAF7]/[0.03] border border-[#FAFAF7]/10 hover:border-[#8DBE3F]/50 transition-colors" data-reveal data-delay={`${i * 100}`}>
            <p class="font-display text-3xl text-[#8DBE3F] m-0 leading-none">{p.num}</p>
            <h3 class="font-extrabold mt-5 leading-tight tracking-[-0.02em]" style="font-size: clamp(1.25rem, 2vw, 1.5rem);">{p.nombre}</h3>
            <p class="mt-2 font-display text-xs text-[#8DBE3F] tracking-wide">{p.para}</p>
            <p class="mt-4 text-base leading-relaxed text-[#FAFAF7]/85">{p.promesa}</p>
            <ul class="mt-5 space-y-2 mb-7">
              {p.incluye.map((item) => (
                <li class="flex gap-2.5 text-sm leading-relaxed text-[#A0A0A0]">
                  <span class="text-[#8DBE3F] shrink-0">→</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href="/trabajemos-juntos/"
              data-ga-event="cta_click"
              data-ga-label={`puerta_${p.num}`}
              class="mt-auto inline-flex items-center gap-2 text-sm font-bold text-[#8DBE3F] hover:text-[#FAFAF7] transition-colors"
            >
              Empezar por aquí <span>→</span>
            </a>
          </div>
        ))}
      </div>

      <p class="mt-10 text-sm text-[#6B6B6B] max-w-2xl" data-reveal>
        ¿No sabes cuál encaja? Cuéntame tu reto en el <a href="/trabajemos-juntos/" data-ga-event="cta_click" data-ga-label="puertas_formulario" class="underline text-[#A0A0A0] hover:text-[#8DBE3F]">formulario</a> y te oriento yo.
      </p>
    </div>
  </section>

  <!-- CÓMO SUELO TRABAJAR -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container-wide py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#8DBE3F] m-0">§ 01</p>
          <p class="font-display text-xs text-[#A0A0A0] mt-2">CÓMO SUELO TRABAJAR</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 3rem); max-width: 14ch;" data-mask-up>
            <span>Un método, no una ocurrencia.</span>
          </h2>
        </div>
        <div class="md:col-span-8">
          {comoTrabajo.map((m, i) => (
            <div class="py-6 grid grid-cols-1 sm:grid-cols-12 gap-4" style={i > 0 ? 'border-top: 1px solid rgba(255,255,255,0.1);' : ''} data-reveal data-delay={`${i * 80}`}>
              <p class="sm:col-span-2 font-display text-3xl text-[#8DBE3F] m-0 leading-none">{m.num}</p>
              <div class="sm:col-span-10">
                <h3 class="font-extrabold m-0 leading-tight tracking-[-0.02em]" style="font-size: clamp(1.2rem, 2.2vw, 1.6rem);">{m.titulo}</h3>
                <p class="mt-2 text-base md:text-lg leading-relaxed text-[#A0A0A0] max-w-2xl">{m.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PARA QUIÉN TIENE SENTIDO -->
  <section class="bg-[#FAFAF7] text-[#1A1A1A]">
    <div class="container-wide py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#467010] m-0">§ 02</p>
          <p class="font-display text-xs text-[#6B6B6B] mt-2">PARA QUIÉN</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 3rem); max-width: 12ch;" data-mask-up>
            <span>Para quién tiene sentido.</span>
          </h2>
        </div>
        <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-7">
          {paraQuien.map((p, i) => (
            <div class="flex gap-3" data-reveal data-delay={`${i * 70}`}>
              <span class="text-[#8DBE3F] font-bold">→</span>
              <p class="m-0 text-base md:text-lg leading-relaxed text-[#3D3D3D]">{p}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- QUÉ NO HAGO -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container-wide py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4">
          <span class="acento-verde block mb-6" data-reveal></span>
          <p class="font-display text-xs text-[#8DBE3F] m-0">§ 03</p>
          <p class="font-display text-xs text-[#A0A0A0] mt-2">QUÉ NO HAGO</p>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 3rem); max-width: 14ch;" data-mask-up>
            <span>Criterio también es decir que no.</span>
          </h2>
        </div>
        <div class="md:col-span-8">
          {queNoHago.map((q, i) => (
            <div class="flex gap-3 py-4" style={i > 0 ? 'border-top: 1px solid rgba(255,255,255,0.1);' : ''} data-reveal data-delay={`${i * 70}`}>
              <span class="text-[#8DBE3F] font-bold shrink-0">✕</span>
              <p class="m-0 text-base md:text-lg leading-relaxed text-[#A0A0A0]">{q}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container-wide py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-end">
        <div class="md:col-span-7">
          <span class="acento-verde block mb-6" data-reveal></span>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[0.95] m-0" style="font-size: clamp(2.5rem, 7vw, 5rem);">
            <span data-mask-up>¿Hablamos?</span>
          </h2>
          <p class="mt-8 text-lg md:text-xl text-[#A0A0A0] max-w-xl leading-relaxed" data-reveal data-delay="200">
            Cuéntame tu reto y te digo si encaja con alguno de estos servicios y cómo lo abordaría.
          </p>
        </div>
        <div class="md:col-span-5 md:text-right" data-reveal data-delay="300">
          <a href="/trabajemos-juntos/" data-magnetic="0.3" class="inline-flex items-center gap-2 px-10 py-5 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
            Cuéntame tu reto →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
