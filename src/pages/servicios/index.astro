---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const servicios = (await getCollection('services', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Servicios"
  seoTitle="Servicios de comunicación, sostenibilidad e IA"
  description="Comunicación estratégica, comunicación de sostenibilidad y ESG, IA aplicada, automatización y formación. Así puedo ayudar a tu organización."
>
  <!-- HERO -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7] pt-32 pb-16">
    <div class="container-wide">
      <span class="acento-verde block mb-6" data-mask-up></span>
      <p class="font-display text-xs text-[#8DBE3F] m-0" data-reveal>SERVICIOS</p>
      <h1
        class="m-0 font-extrabold leading-[0.9] tracking-[-0.03em] mt-4"
        style="font-size: clamp(2.5rem, 8vw, 6rem); max-width: 16ch;"
      >
        <span data-mask-up>Cómo puedo ayudarte.</span>
      </h1>
      <p class="mt-8 text-lg md:text-xl leading-relaxed text-[#FAFAF7]/85 max-w-2xl" data-reveal data-delay="200">
        Tres mundos, un mismo criterio: comunicación, sostenibilidad e inteligencia artificial al servicio de
        organizaciones que quieren decidir mejor, explicar mejor y avanzar con dirección.
      </p>
    </div>
  </section>

  <!-- LISTA -->
  <section class="bg-[#FAFAF7] text-[#1A1A1A]">
    <div class="container-wide py-20 md:py-28">
      {servicios.map((s, i) => (
        <a
          href={`/${s.slug}/`}
          class="group grid grid-cols-1 md:grid-cols-12 gap-6 py-10"
          style={i > 0 ? 'border-top: 1px solid #E5E5E0;' : ''}
          data-reveal
          data-delay={`${i * 80}`}
        >
          <div class="md:col-span-1">
            <p class="font-display text-3xl text-[#8DBE3F] m-0 leading-none">0{i + 1}</p>
          </div>
          <div class="md:col-span-7">
            <h2 class="font-extrabold m-0 leading-tight tracking-[-0.02em] group-hover:text-[#467010] transition-colors" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
              {s.data.title}
            </h2>
            <p class="mt-3 text-base md:text-lg leading-relaxed text-[#3D3D3D] max-w-xl">{s.data.description}</p>
          </div>
          <div class="md:col-span-4 md:text-right flex md:block items-center">
            <span class="font-display text-sm text-[#1A1A1A] group-hover:text-[#467010] transition-colors inline-flex items-center gap-2">
              Ver servicio <span class="text-[#8DBE3F] group-hover:translate-x-1 transition-transform">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#1A1A1A] text-[#FAFAF7]">
    <div class="container-wide py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-end">
        <div class="md:col-span-7">
          <span class="acento-verde block mb-6" data-reveal></span>
          <h2 class="font-extrabold tracking-[-0.03em] leading-[0.95] m-0" style="font-size: clamp(2.5rem, 7vw, 5rem);">
            <span data-mask-up>¿Hablamos?</span>
          </h2>
          <p class="mt-8 text-lg md:text-xl text-[#A0A0A0] max-w-xl leading-relaxed" data-reveal data-delay="200">
            Cuéntame tu reto y te digo si encaja con alguno de estos servicios y cómo lo abordaría.
          </p>
        </div>
        <div class="md:col-span-5 md:text-right" data-reveal data-delay="300">
          <a href="/trabajemos-juntos/" data-magnetic="0.3" class="inline-flex items-center gap-2 px-10 py-5 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors">
            Cuéntame tu reto →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
