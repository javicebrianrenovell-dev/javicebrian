---
import Monograma from './Monograma.astro';

const navItems = [
  { label: 'Quién soy', href: '/quien-soy/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contacto', href: '/contacto/' },
];

const cta = { label: 'Empezar proyecto', href: '/trabajemos-juntos/' };

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[#1A1A1A]/95 border-b border-white/5">
  <div class="container-base flex items-center justify-between py-5">
    <a href="/" class="flex items-center gap-3 group" aria-label="Javi Cebrián — inicio">
      <Monograma size={40} variant="blanco" withAccent={true} class="transition-transform group-hover:scale-105" />
      <span class="text-[#FAFAF7] font-bold text-lg tracking-tight hidden sm:block">
        Javi Cebrián
      </span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-2" aria-label="Navegación principal">
      {navItems.map(({ label, href }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a
            href={href}
            class:list={[
              'px-3 py-2 text-sm font-medium transition-colors rounded-md',
              isActive
                ? 'text-[#8DBE3F]'
                : 'text-[#FAFAF7]/80 hover:text-[#FAFAF7]'
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            {label}
          </a>
        );
      })}
      <a
        href={cta.href}
        class:list={[
          'ml-2 px-4 py-2 text-xs sm:text-sm font-bold uppercase tracking-wider rounded-md transition-colors',
          currentPath.startsWith(cta.href)
            ? 'bg-[#FAFAF7] text-[#1A1A1A]'
            : 'bg-[#8DBE3F] text-[#1A1A1A] hover:bg-[#FAFAF7]'
        ]}
        aria-current={currentPath.startsWith(cta.href) ? 'page' : undefined}
      >
        {cta.label}
      </a>
    </nav>
  </div>
</header>
