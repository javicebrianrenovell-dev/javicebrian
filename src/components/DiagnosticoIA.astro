---
// Diagnóstico IA en 2 minutos — gancho de captación.
// 4 preguntas → lectura personalizada (plantilla + frase IA en vivo) → dos puertas (WhatsApp / correo).
// Backend: workflow n8n "Diagnóstico web IA" (upsert Notion + aviso Telegram).
interface Props {
  webhook?: string;
  wa?: string;
}
const {
  webhook = 'https://n8ntest.javicebrian.es/webhook/diagnostico-ia',
  wa = '34694218846',
} = Astro.props;
---

<section id="diagnostico" class="bg-[#1A1A1A] text-[#FAFAF7]" style="border-top: 1px solid rgba(255,255,255,0.06);">
  <div class="container-wide py-24 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-4 md:sticky md:top-28">
        <span class="acento-verde block mb-6" data-reveal></span>
        <p class="font-display text-xs text-[#8DBE3F] m-0">§ EN 2 MINUTOS</p>
        <p class="font-display text-xs text-[#A0A0A0] mt-2">DIAGNÓSTICO IA</p>
        <h2 class="font-extrabold tracking-[-0.03em] leading-[1.05] mt-6" style="font-size: clamp(1.75rem, 3.5vw, 3rem); max-width: 14ch;" data-mask-up>
          <span>¿Por dónde empezar con la IA?</span>
        </h2>
        <p class="mt-6 text-base leading-relaxed text-[#A0A0A0] max-w-md" data-reveal data-delay="120">
          Cuatro preguntas. Te devuelvo al instante una lectura honesta de por dónde empezaría yo en tu caso. Sin compromiso.
        </p>
      </div>

      <div class="md:col-span-8" data-reveal data-delay="100">
        <div class="dia-card p-7 md:p-9 rounded-lg bg-[#FAFAF7]/[0.03] border border-[#FAFAF7]/10" data-webhook={webhook} data-wa={wa}>
          <div class="flex items-center justify-between mb-3">
            <p class="font-display text-xs text-[#FAFAF7] m-0 dia-step">PASO 1 DE 4</p>
            <p class="font-display text-xs text-[#A0A0A0] m-0 dia-pct">25%</p>
          </div>
          <div class="h-1 bg-white/10 rounded-full overflow-hidden mb-8">
            <div class="dia-bar h-full bg-[#8DBE3F] transition-all duration-500 ease-out" style="width:25%"></div>
          </div>
          <div class="dia-body"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var SECTORS = ["Residuos", "Ambiental B2B", "Servicios locales", "Otro"];
    var MADUREZ = ["Solo ChatGPT suelto", "Alguna prueba", "Nada aún", "Ya tenemos algo"];
    var DOLOR = {
      "Residuos": ["Avisos e incidencias", "Documentación y licitaciones", "Reporting e informes", "No lo tengo claro"],
      "_def": ["Atención y consultas", "Documentación y propuestas", "Reporting e informes", "No lo tengo claro"]
    };
    var DECISION = ["Yo decido", "Decido con alguien", "Solo explorando"];

    var OPT = "dia-opt w-full text-left px-5 py-4 mb-3 rounded-lg border border-[#FAFAF7]/15 hover:border-[#8DBE3F] hover:bg-[#8DBE3F]/10 transition-colors text-[#FAFAF7] text-base block";
    var Q = "text-xl md:text-2xl font-extrabold tracking-[-0.02em] mb-5 text-[#FAFAF7]";
    var LABEL = "font-display text-xs text-[#8DBE3F] m-0 mb-2";
    var WABTN = "block w-full text-center px-8 py-4 bg-[#8DBE3F] text-[#1A1A1A] font-bold text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7] transition-colors no-underline";
    var MAILBTN = "block w-full text-center px-8 py-4 mt-3 border border-[#FAFAF7]/20 text-[#FAFAF7] font-medium text-sm uppercase tracking-wider rounded-md hover:bg-[#FAFAF7]/5 transition-colors cursor-pointer";
    var INPUT = "w-full px-4 py-3 mt-3 rounded-md bg-[#1A1A1A] border border-[#FAFAF7]/20 text-[#FAFAF7] text-base";

    function esc(s) { return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }

    function init(root) {
      var body = root.querySelector(".dia-body");
      var bar = root.querySelector(".dia-bar");
      var stepEl = root.querySelector(".dia-step");
      var pctEl = root.querySelector(".dia-pct");
      var wh = root.getAttribute("data-webhook");
      var wa = root.getAttribute("data-wa");
      var a = {};
      var step = 0;
      var steps = [
        { k: "sector", q: "¿En qué se mueve tu empresa?", opts: function () { return SECTORS; } },
        { k: "madurez", q: "¿Dónde estáis con la IA?", opts: function () { return MADUREZ; } },
        { k: "dolor", q: "¿Qué se te atasca o te come tiempo?", opts: function () { return DOLOR[a.sector] || DOLOR._def; } },
        { k: "decision", q: "¿Tú decides y hay ganas de moverlo?", opts: function () { return DECISION; } }
      ];

      function render() {
        if (step < steps.length) {
          var s = steps[step];
          stepEl.textContent = "PASO " + (step + 1) + " DE 4";
          pctEl.textContent = Math.round((step / 4) * 100) + "%";
          bar.style.width = (step / 4) * 100 + "%";
          var html = '<p class="' + Q + '">' + esc(s.q) + '</p>';
          var opts = s.opts();
          for (var i = 0; i < opts.length; i++) {
            html += '<button type="button" class="' + OPT + '" data-v="' + esc(opts[i]) + '">' + esc(opts[i]) + '</button>';
          }
          body.innerHTML = html;
          var btns = body.querySelectorAll(".dia-opt");
          for (var j = 0; j < btns.length; j++) {
            btns[j].addEventListener("click", function (e) {
              a[s.k] = e.currentTarget.getAttribute("data-v");
              step++;
              render();
            });
          }
        } else {
          finish();
        }
      }

      function finish() {
        stepEl.textContent = "TU DIAGNÓSTICO";
        pctEl.textContent = "100%";
        bar.style.width = "100%";
        body.innerHTML = '<p class="' + Q + '">Analizando…</p>';
        var done = function (fraseIA) {
          var veo = "Una empresa de " + a.sector.toLowerCase() + " que " + (a.madurez === "Nada aún" ? "aún no ha entrado en la IA" : "ya tantea la IA pero no pasa de ahí") + ". El cuello está en " + a.dolor.toLowerCase() + ".";
          var waText = encodeURIComponent("Hola Javi, vengo del diagnóstico de tu web. Sector: " + a.sector + ". Madurez: " + a.madurez + ". Me atasca: " + a.dolor + ". Quiero ver por dónde empezar.");
          var html = '';
          html += '<div class="mb-5"><p class="' + LABEL + '">LO QUE VEO</p><p class="text-[#FAFAF7]/90 leading-relaxed m-0">' + esc(veo) + '</p></div>';
          if (fraseIA) {
            html += '<div class="mb-5 p-5 rounded-lg bg-[#8DBE3F]/10 border border-[#8DBE3F]/30"><p class="' + LABEL + '">HECHO A TU CASO</p><p class="text-[#FAFAF7] leading-relaxed m-0">' + esc(fraseIA) + '</p></div>';
          }
          html += '<div class="mb-6"><p class="' + LABEL + '">POR DÓNDE EMPEZARÍA</p><p class="text-[#FAFAF7]/90 leading-relaxed m-0">Un Diagnóstico de 14 días: mapa de casos priorizado y un primer caso ya funcionando.</p></div>';
          html += '<a class="' + WABTN + '" href="https://wa.me/' + wa + '?text=' + waText + '" data-ga-event="cta_click" data-ga-label="diagnostico_whatsapp">Concrétalo por WhatsApp con Javi</a>';
          html += '<button type="button" class="' + MAILBTN + '" id="dia-mailbtn">Mándame el diagnóstico ampliado</button>';
          html += '<div id="dia-mailbox"></div>';
          body.innerHTML = html;
          var mb = root.querySelector("#dia-mailbtn");
          mb.addEventListener("click", function () {
            var box = root.querySelector("#dia-mailbox");
            box.innerHTML = '<input class="' + INPUT + '" type="email" placeholder="tu@correo.com" id="dia-email"><button type="button" class="' + MAILBTN + '" id="dia-send" style="margin-top:8px">Enviar</button><p class="text-xs text-[#6B6B6B] mt-3 m-0">Solo para que Javi te amplíe el diagnóstico. Nada de spam.</p>';
            root.querySelector("#dia-send").addEventListener("click", function () {
              var email = (root.querySelector("#dia-email") || {}).value || "";
              try {
                fetch(wh, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ sector: a.sector, madurez: a.madurez, dolor: a.dolor, decision: a.decision, email: email }) });
              } catch (e) {}
              box.innerHTML = '<p class="text-sm text-[#8DBE3F] mt-3 m-0">Hecho. Javi te escribe pronto.</p>';
            });
          });
        };
        try {
          fetch(wh, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(a) })
            .then(function (r) { return r.json(); })
            .then(function (d) { done((d && d.fraseIA) || ""); })
            .catch(function () { done(""); });
        } catch (e) { done(""); }
      }

      render();
    }

    function boot() {
      var nodes = document.querySelectorAll(".dia-card");
      for (var i = 0; i < nodes.length; i++) init(nodes[i]);
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", boot);
    } else {
      boot();
    }
  })();
</script>
