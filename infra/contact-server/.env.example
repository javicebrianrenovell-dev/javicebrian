# Copia este archivo a .env en el VPS y rellena con valores reales.
# .env NO se sube a Git (ya está en .gitignore del repo padre).

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=jcebrian@grupimedes.com
CONTACT_FROM_EMAIL=web@javicebrian.es

# Opcionales:
PORT=3001
ALLOWED_ORIGIN=https://javicebrian.es

# Persistencia leads cualificados (append-only JSONL).
# Si no existe el directorio, el servicio lo crea al primer lead.
LEADS_FILE=/var/lib/javicebrian/leads.jsonl
